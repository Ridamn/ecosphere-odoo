<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Define Module Category -->
    <record id="module_category_ecosphere" model="ir.module.category">
        <field name="name">EcoSphere ESG</field>
        <field name="description">Helps track Environmental, Social, and Governance metrics.</field>
        <field name="sequence">10</field>
    </record>

    <!-- EcoSphere User Group -->
    <record id="group_ecosphere_user" model="res.groups">
        <field name="name">EcoSphere User / Employee</field>
        <field name="category_id" ref="module_category_ecosphere"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <!-- EcoSphere Manager Group -->
    <record id="group_ecosphere_manager" model="res.groups">
        <field name="name">EcoSphere Manager / Admin</field>
        <field name="category_id" ref="module_category_ecosphere"/>
        <field name="implied_ids" eval="[(4, ref('group_ecosphere_user'))]"/>
        <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>

    <!-- EcoSphere Auditor Group -->
    <record id="group_ecosphere_auditor" model="res.groups">
        <field name="name">EcoSphere Auditor</field>
        <field name="category_id" ref="module_category_ecosphere"/>
        <field name="implied_ids" eval="[(4, ref('group_ecosphere_user'))]"/>
    </record>
</odoo>
